#  Server 
PORT=5000
NODE_ENV=development

# MongoDB 
MONGO_URI=mongodb://localhost:27017/taskdesk
# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskdesk

#  JWT 
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer)
# For development use Mailtrap: https://mailtrap.io
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@taskflow.io
EMAIL_FROM_NAME=TaskFlow

# Frontend URL (for password reset link)
CLIENT_URL=http://localhost:5173
